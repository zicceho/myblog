# 文档站 Giscus（复制为 .env.docs.local 后用于本地 yarn docs:site:dev / build）
# GitHub Actions 请在仓库 Settings → Secrets 配置同名变量

VITE_GISCUS_REPO_ID=R_kgDOGHdxTw
VITE_GISCUS_CATEGORY_ID=DIC_kwDOGHdxT84CBR2I

# 可选：文档站右下角 AI 助手接口。
# Cloudflare Pages Functions 路径用 /api/docs-chat，不需要 Docker。
# Gemini API Key 不要写到 VITE_ 前端变量里，请在 Cloudflare Pages 的 Variables and Secrets 里新增 Secret。
# VITE_DOCS_CHAT_API=/api/docs-chat
# GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# DOCS_CHAT_MODEL=gemini-flash-lite-latest

# 可选：设为 false 关闭页底评论
# VITE_GISCUS_ENABLED=false
